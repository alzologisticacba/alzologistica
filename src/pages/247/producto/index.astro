---
// src/pages/247/producto/index.astro
// Redirige URLs viejas (?codigo=X) a las URLs limpias (/247/producto/slug)
export const prerender = false;
import { supabase } from "../../../lib/supabase";
import { productSlug } from "../../../lib/slugify";

const codigo = Astro.url.searchParams.get("codigo");

if (codigo) {
  const { data } = await supabase
    .from("articulos")
    .select("codigo, descripcion")
    .eq("codigo", parseInt(codigo))
    .single();

  if (data) {
    return Astro.redirect(`/247/producto/${productSlug(data.descripcion, data.codigo)}`, 301);
  }
}

return Astro.redirect("/247", 302);
---

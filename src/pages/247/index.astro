---
// src/pages/247/index.astro
import Layout247 from "../../layouts/Layout247.astro";
import App247 from "../../components/247/App247";
import "../../styles/247.css";
import { getAllArticulosConStock } from "../../lib/articulosCache";
import { supabase } from "../../lib/supabase";

const EXCLUIR = ["Cigarrillos", "Tabaco", "Tabacos", "Cigarros", "Cigarette"];

function shuffle<T>(arr: T[]): T[] {
  const a = [...arr];
  for (let i = a.length - 1; i > 0; i--) {
    const j = Math.floor(Math.random() * (i + 1));
    [a[i], a[j]] = [a[j], a[i]];
  }
  return a;
}

const allArticulos = await getAllArticulosConStock();

// Solo los campos que ProductCard usa en el primer render — reduce HTML + hidratación
function lite(a: any) {
  return {
    codigo:        a.codigo,
    descripcion:   a.descripcion,
    rubro:         a.rubro,
    precioFinal:   a.precioFinal,
    descuento:     a.descuento,
    multiplo:      a.multiplo,
    familiaNombre: a.familiaNombre,
  };
}

const initialDescuentos  = shuffle(allArticulos.filter(a => a.descuento > 0)).slice(0, 8).map(lite);
const initialTodos       = shuffle(allArticulos.filter(a => !EXCLUIR.includes(a.familiaNombre))).slice(0, 8).map(lite);
const initialCigarrillos = shuffle(allArticulos.filter(a => (a.familiaNombre ?? "").toLowerCase() === "cigarrillos")).slice(0, 8).map(lite);

const { data: combosData } = await supabase
  .from("combos")
  .select("cod_combo, nombre, precio, descripcion, imagen")
  .eq("activo", true)
  .limit(10);

const initialFamilias = [...new Set(allArticulos.map(a => a.familiaNombre).filter(Boolean))].sort();

const websiteLd = JSON.stringify({
  "@context": "https://schema.org",
  "@type": "WebSite",
  "name": "Alzo 24/7",
  "url": "https://alzologistica.com/247",
  "description": "Plataforma mayorista online de Alzo Logística. Golosinas, bebidas, almacén y más para kioscos y autoservicios de Córdoba.",
  "potentialAction": {
    "@type": "SearchAction",
    "target": {
      "@type": "EntryPoint",
      "urlTemplate": "https://alzologistica.com/247/todos?q={search_term_string}"
    },
    "query-input": "required name=search_term_string"
  }
});

const orgLd = JSON.stringify({
  "@context": "https://schema.org",
  "@type": "Organization",
  "name": "Alzo Logística",
  "url": "https://alzologistica.com",
  "logo": "https://alzologistica.com/img/alzo_logo.png",
  "contactPoint": [
    { "@type": "ContactPoint", "telephone": "+54-9-351-327-6516", "contactType": "sales", "areaServed": "AR", "availableLanguage": "Spanish" },
    { "@type": "ContactPoint", "telephone": "+54-9-351-201-9862", "contactType": "billing", "areaServed": "AR", "availableLanguage": "Spanish" }
  ]
});
---

<Layout247
  canonical="https://alzologistica.com/247"
  description="Pedí mayorista online 24/7 sin registros. Golosinas, bebidas, almacén, cigarrillos y más para kioscos, autoservicios y comercios de Córdoba."
>
  <script is:inline slot="head" type="application/ld+json" set:html={websiteLd} />
  <script is:inline slot="head" type="application/ld+json" set:html={orgLd} />
  <App247
    initialSections={{
      descuentos:   initialDescuentos,
      combos:       combosData ?? [],
      todos:        initialTodos,
      cigarrillos:  initialCigarrillos,
    }}
    initialFamilias={initialFamilias}
    client:load
  />
</Layout247>

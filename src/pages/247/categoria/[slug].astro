---
// src/pages/247/categoria/[slug].astro
import Layout247 from "../../../layouts/Layout247.astro";
import CategoryPage from "../../../components/247/CategoryPage";
import "../../../styles/247.css";
import "../../../styles/categoria.css";
import { getAllArticulosConStock } from "../../../lib/articulosCache";

export async function getStaticPaths() {
  const data = await getAllArticulosConStock();

  const familiasMap = new Map<string, typeof data>();
  for (const row of data) {
    const f = row.familiaNombre as string;
    if (!f) continue;
    if (!familiasMap.has(f)) familiasMap.set(f, []);
    familiasMap.get(f)!.push(row);
  }

  return [...familiasMap.entries()].map(([familia, articulos]) => ({
    params: { slug: familia.toLowerCase().replace(/\s+/g, "-") },
    props: { familia, titulo: familia, articulos: articulos ?? [] },
  }));
}

const { familia, titulo, articulos } = Astro.props;
const slug = familia.toLowerCase().replace(/\s+/g, "-");

const breadcrumbLd = JSON.stringify({
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Alzo 24/7", "item": "https://alzologistica.com/247" },
    { "@type": "ListItem", "position": 2, "name": titulo, "item": `https://alzologistica.com/247/categoria/${slug}` }
  ]
});
---

<Layout247
  title={`${titulo} | Alzo 24/7`}
  description={`Comprá ${titulo} al por mayor 24/7 sin registros. Precios mayoristas para kioscos, autoservicios y comercios de Córdoba. Pedí online con Alzo Logística.`}
  canonical={`https://alzologistica.com/247/categoria/${slug}`}
>
  <script is:inline slot="head" type="application/ld+json" set:html={breadcrumbLd} />
  <CategoryPage familia={familia} titulo={titulo} initialArticulos={articulos} client:load />
</Layout247>
---
// src/pages/247/combos.astro
import Layout247 from "../../layouts/Layout247.astro";
import CombosPage from "../../components/247/CombosPage";
import "../../styles/247.css";
import { supabase } from "../../lib/supabase";

const { data: combos } = await supabase
  .from("combos")
  .select("cod_combo, nombre, precio, descripcion, imagen")
  .eq("activo", true)
  .order("nombre", { ascending: true })
  .limit(100);
---
<Layout247
  title="Combos | Alzo 24/7"
  description="Combos mayoristas armados para kioscos y autoservicios. Golosinas, bebidas y almacén al mejor precio, sin registros. Pedí online 24/7 con Alzo Logística."
  canonical="https://alzologistica.com/247/combos"
>
  <CombosPage initialCombos={combos ?? []} client:load />
</Layout247>
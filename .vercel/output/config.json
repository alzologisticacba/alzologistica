{
	"version": 3,
	"routes": [
		{
			"handle": "filesystem"
		},
		{
			"src": "^/_astro/(.*)$",
			"headers": {
				"cache-control": "public, max-age=31536000, immutable"
			},
			"continue": true
		},
		{
			"src": "^/_server-islands/([^/]+?)/?$",
			"dest": "_render"
		},
		{
			"src": "^/_image/?$",
			"dest": "_render"
		},
		{
			"src": "^/api/articulos/?$",
			"dest": "_render"
		},
		{
			"src": "^/api/buscar/?$",
			"dest": "_render"
		},
		{
			"src": "^/api/catalogo/?$",
			"dest": "_render"
		},
		{
			"src": "^/api/combos/?$",
			"dest": "_render"
		},
		{
			"src": "^/api/debug-familias/?$",
			"dest": "_render"
		},
		{
			"src": "^/api/descuentos/?$",
			"dest": "_render"
		},
		{
			"src": "^/api/familias/?$",
			"dest": "_render"
		},
		{
			"src": "^/api/reparto/digip/?$",
			"dest": "_render"
		},
		{
			"src": "^/api/reparto/repartidores/?$",
			"dest": "_render"
		},
		{
			"src": "^/api/reparto/verificar-patente/?$",
			"dest": "_render"
		},
		{
			"src": "^/api/rubros/?$",
			"dest": "_render"
		},
		{
			"src": "^/api/vencimientos/digip/?$",
			"dest": "_render"
		}
	]
}